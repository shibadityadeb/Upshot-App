generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  admin
  company
  people
  ambassador
  student

  @@map("user_role")
}

enum EventStatus {
  draft
  pending
  approved
  rejected
  completed
  cancelled

  @@map("event_status")
}

enum ApplicationStatus {
  pending
  approved
  rejected
  withdrawn

  @@map("application_status")
}

enum TaskStatus {
  assigned
  in_progress
  submitted
  approved
  rejected

  @@map("task_status")
}

enum TransactionType {
  earned
  redeemed
  bonus
  penalty

  @@map("transaction_type")
}

enum AmbassadorTier {
  bronze
  silver
  gold
  platinum

  @@map("ambassador_tier")
}

// ─── Models ──────────────────────────────────────────────

model Profile {
  id        String   @id @db.Uuid
  email     String
  fullName  String   @map("full_name")
  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(people)
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  companiesOwned      Company[]          @relation("CompanyContact")
  eventsCreated       Event[]            @relation("EventCreator")
  eventsApproved      Event[]            @relation("EventApprover")
  eventApplications   EventApplication[] @relation("Applicant")
  reviewedApplications EventApplication[] @relation("ApplicationReviewer")
  tasksAssigned       Task[]             @relation("TaskAssignee")
  tasksCreated        Task[]             @relation("TaskAssigner")
  coinTransactions    CoinTransaction[]
  walletBalance       WalletBalance?
  ambassador          Ambassador?
  student             Student?
  notifications       Notification[]

  @@map("profiles")
}

model Company {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  logoUrl         String?  @map("logo_url")
  website         String?
  industry        String?
  description     String?
  contactPersonId String   @map("contact_person_id") @db.Uuid
  isVerified      Boolean  @default(false) @map("is_verified")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  contactPerson Profile @relation("CompanyContact", fields: [contactPersonId], references: [id])
  events        Event[]

  @@map("companies")
}

model Event {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String
  companyId        String      @map("company_id") @db.Uuid
  eventDate        DateTime    @map("event_date") @db.Date
  eventTime        DateTime?   @map("event_time") @db.Time
  location         String
  locationUrl      String?     @map("location_url")
  category         String
  bannerUrl        String?     @map("banner_url")
  maxAttendees     Int?        @map("max_attendees")
  currentAttendees Int         @default(0) @map("current_attendees")
  status           EventStatus @default(draft)
  requirements     String?
  coinReward       Int         @default(0) @map("coin_reward")
  createdBy        String      @map("created_by") @db.Uuid
  approvedBy       String?     @map("approved_by") @db.Uuid
  approvedAt       DateTime?   @map("approved_at") @db.Timestamptz
  rejectionReason  String?     @map("rejection_reason")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  company      Company            @relation(fields: [companyId], references: [id])
  creator      Profile            @relation("EventCreator", fields: [createdBy], references: [id])
  approver     Profile?           @relation("EventApprover", fields: [approvedBy], references: [id])
  requirements_list EventRequirement[]
  applications EventApplication[]
  tasks        Task[]

  @@index([status])
  @@index([companyId])
  @@index([eventDate])
  @@map("events")
}

model EventRequirement {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  label     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_requirements")
}

model EventApplication {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId    String            @map("event_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  status     ApplicationStatus @default(pending)
  note       String?
  appliedAt  DateTime          @default(now()) @map("applied_at") @db.Timestamptz
  reviewedAt DateTime?         @map("reviewed_at") @db.Timestamptz
  reviewedBy String?           @map("reviewed_by") @db.Uuid

  // Relations
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     Profile  @relation("Applicant", fields: [userId], references: [id])
  reviewer Profile? @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@map("event_applications")
}

model Task {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  description    String
  eventId        String?    @map("event_id") @db.Uuid
  assignedTo     String     @map("assigned_to") @db.Uuid
  assignedBy     String     @map("assigned_by") @db.Uuid
  status         TaskStatus @default(assigned)
  dueDate        DateTime?  @map("due_date") @db.Date
  coinValue      Int        @default(0) @map("coin_value")
  submissionUrl  String?    @map("submission_url")
  submissionNote String?    @map("submission_note")
  submittedAt    DateTime?  @map("submitted_at") @db.Timestamptz
  reviewedAt     DateTime?  @map("reviewed_at") @db.Timestamptz
  reviewNote     String?    @map("review_note")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event    Event?  @relation(fields: [eventId], references: [id])
  assignee Profile @relation("TaskAssignee", fields: [assignedTo], references: [id])
  assigner Profile @relation("TaskAssigner", fields: [assignedBy], references: [id])

  @@index([assignedTo])
  @@index([status])
  @@map("tasks")
}

model WalletBalance {
  userId         String @id @map("user_id") @db.Uuid
  totalEarned    Int    @default(0) @map("total_earned")
  totalRedeemed  Int    @default(0) @map("total_redeemed")
  currentBalance Int    @default(0) @map("current_balance")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallet_balances")
}

model CoinTransaction {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  type          TransactionType
  amount        Int
  description   String
  referenceId   String?         @map("reference_id")
  referenceType String?         @map("reference_type")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("coin_transactions")
}

model Ambassador {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @unique @map("user_id") @db.Uuid
  referralCode    String        @unique @map("referral_code")
  referralCount   Int           @default(0) @map("referral_count")
  totalCoinsEarned Int          @default(0) @map("total_coins_earned")
  tier            AmbassadorTier @default(bronze)
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user     Profile   @relation(fields: [userId], references: [id])
  students Student[]

  @@index([referralCode])
  @@map("ambassadors")
}

model Student {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  college        String?
  course         String?
  yearOfStudy    Int?     @map("year_of_study")
  ambassadorCode String?  @map("ambassador_code")
  referredBy     String?  @map("referred_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user      Profile     @relation(fields: [userId], references: [id])
  referrer  Ambassador? @relation(fields: [referredBy], references: [id])

  @@map("students")
}

model Notification {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  body        String
  type        String
  referenceId String?  @map("reference_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}
