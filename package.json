{
  "name": "upshot-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @upshot/mobile start",
    "type-check": "yarn workspaces run type-check",
    "db:generate": "yarn workspace @upshot/database db:generate",
    "db:push": "yarn workspace @upshot/database db:push",
    "db:migrate": "yarn workspace @upshot/database db:migrate",
    "db:studio": "yarn workspace @upshot/database db:studio",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "resolutions": {
    "metro": "~0.80.8",
    "metro-cache": "~0.80.8",
    "metro-config": "~0.80.8",
    "metro-core": "~0.80.8",
    "metro-runtime": "~0.80.8",
    "metro-resolver": "~0.80.8",
    "metro-transform-worker": "~0.80.8",
    "metro-file-map": "~0.80.8",
    "metro-source-map": "~0.80.8",
    "metro-transform-plugins": "~0.80.8",
    "metro-cache-key": "~0.80.8",
    "metro-babel-transformer": "~0.80.8",
    "metro-minify-terser": "~0.80.8",
    "metro-symbolicate": "~0.80.8",
    "metro-inspector-proxy": "~0.80.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
