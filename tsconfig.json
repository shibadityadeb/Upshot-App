{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@upshot/types": ["./packages/types/src"],
      "@upshot/api-client": ["./packages/api-client/src"],
      "@upshot/database": ["./packages/database/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
